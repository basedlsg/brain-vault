# OS / editor noise
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
*.swp
*~

# Obsidian — user-local state (workspace layout, recent files, etc.)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache
.obsidian/plugins/*/data.json

# Logs and credentials
automations/scripts/*.log
automations/scripts/*.err.log
automations/**/*.env
automations/**/.env*
*.local.json

# Drafts that shouldn't be committed (use prefix `_draft_` for these)
**/_draft_*

# Personal journal corpus — too large + private; lives in OBSIDIAN/archive/journals/
# Only track the index, not the raw content
archive/journals/*.txt

# But keep these
!.gitkeep

# Generated bookmarklet contains the webhook token
automations/bookmarklet.html
# Browser history snapshots — local, can be regenerated
archive/browser-history/
